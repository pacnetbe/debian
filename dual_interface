#!/usr/bin/env bash
set -euo pipefail

# --------------------------------------------------------
# How to run
# Save the script as setup-systemd-networkd-policy.sh.
# Make it executable:
# sudo chmod +x setup-systemd-networkd-policy.sh
# run as root:
# sudo ./setup-systemd-networkd-policy.sh
# --------------------------------------------------------

# setup-systemd-networkd-policy.sh
# Idempotent installer for systemd-networkd policy routing + systemd-resolved integration.
# Run as root: sudo ./setup-systemd-networkd-policy.sh

# ---- Configuration (edit if needed) ----
MAIN_IF="enp2s0"
CAM_IF="enp1s0"

# If you prefer subnet-based From rules, set CAM_FROM and MAIN_FROM to /24 values
CAM_FROM="10.10.80.24/32"
MAIN_FROM="10.10.10.25/32"

# Gateways used for the per-table defaults. If DHCP gateway may change, consider automation.
CAM_GW="10.10.80.1"
MAIN_GW="10.10.10.1"

RT_TABLE_CAM_ID="100"
RT_TABLE_MAIN_ID="200"
RT_TABLE_CAM_NAME="cam"
RT_TABLE_MAIN_NAME="mainnet"

# Priorities for routing policy rules
PRIO_FROM=100
PRIO_IIF=101
# -----------------------------------------

# Utilities
backup_file() {
  local f="$1"
  if [[ -f "$f" ]]; then
    cp -a "$f" "${f}.bak.$(date +%Y%m%d%H%M%S)"
  fi
}

need_root() {
  if [[ "${EUID:-0}" -ne 0 ]]; then
    echo "This script must be run as root. Use sudo." >&2
    exit 1
  fi
}

# Check required commands and systemd units
check_requirements() {
  local -a cmds=(systemctl networkctl ip resolvectl busctl sed tee mkdir ln)
  local -a missing_cmds=()
  for c in "${cmds[@]}"; do
    if ! command -v "$c" >/dev/null 2>&1; then
      missing_cmds+=("$c")
    fi
  done

  local -a missing_units=()
  # systemd-networkd is required
  if ! systemctl list-unit-files --type=service | grep -q '^systemd-networkd.service'; then
    missing_units+=("systemd-networkd.service")
  fi

  # systemd-resolved is optional but recommended. If missing, report it.
  if ! systemctl list-unit-files --type=service | grep -q '^systemd-resolved.service'; then
    missing_units+=("systemd-resolved.service (recommended but optional)")
  fi

  if [[ ${#missing_cmds[@]} -ne 0 || ${#missing_units[@]} -ne 0 ]]; then
    echo "Missing components detected. Install or enable the following and re-run the script:" >&2
    if [[ ${#missing_cmds[@]} -ne 0 ]]; then
      echo "  Missing commands: ${missing_cmds[*]}" >&2
    fi
    if [[ ${#missing_units[@]} -ne 0 ]]; then
      for u in "${missing_units[@]}"; do
        echo "  $u" >&2
      done
    fi
    exit 2
  fi
}

# Create /etc/iproute2/rt_tables entries if not present
ensure_rt_tables() {
  local f="/etc/iproute2/rt_tables"
  backup_file "$f"
  mkdir -p "$(dirname "$f")"
  touch "$f"
  # Ensure reserved header exists
  if ! grep -q '^255\s\+local' "$f"; then
    cat >>"$f" <<'EOF'
# reserved values
255     local
254     main
253     default
0       unspec
EOF
  fi
  # Add custom tables if missing
  if ! grep -qE "^\s*${RT_TABLE_CAM_ID}\s+${RT_TABLE_CAM_NAME}\s*$" "$f"; then
    echo "${RT_TABLE_CAM_ID}     ${RT_TABLE_CAM_NAME}" >>"$f"
  fi
  if ! grep -qE "^\s*${RT_TABLE_MAIN_ID}\s+${RT_TABLE_MAIN_NAME}\s*$" "$f"; then
    echo "${RT_TABLE_MAIN_ID}     ${RT_TABLE_MAIN_NAME}" >>"$f"
  fi
}

# Write systemd-networkd .network files
write_network_files() {
  mkdir -p /etc/systemd/network
  # enp1s0 (camera)
  local fcam="/etc/systemd/network/10-${CAM_IF}.network"
  backup_file "$fcam"
  cat >"$fcam" <<EOF
[Match]
Name=${CAM_IF}

[Network]
DHCP=yes

[DHCP]
UseRoutes=no

[Route]
Destination=${CAM_FROM%/*}/24
Scope=link
Table=${RT_TABLE_CAM_ID}

[Route]
Destination=0.0.0.0/0
Gateway=${CAM_GW}
Table=${RT_TABLE_CAM_ID}

[RoutingPolicyRule]
From=${CAM_FROM}
Table=${RT_TABLE_CAM_ID}
Priority=${PRIO_FROM}

[RoutingPolicyRule]
IncomingInterface=${CAM_IF}
Table=${RT_TABLE_CAM_ID}
Priority=${PRIO_IIF}
EOF

  # enp2s0 (main)
  local fmain="/etc/systemd/network/20-${MAIN_IF}.network"
  backup_file "$fmain"
  cat >"$fmain" <<EOF
[Match]
Name=${MAIN_IF}

[Network]
DHCP=yes

[DHCP]
UseRoutes=no

[Route]
Destination=${MAIN_FROM%/*}/24
Scope=link
Table=${RT_TABLE_MAIN_ID}

[Route]
Destination=0.0.0.0/0
Gateway=${MAIN_GW}
Table=${RT_TABLE_MAIN_ID}

[RoutingPolicyRule]
From=${MAIN_FROM}
Table=${RT_TABLE_MAIN_ID}
Priority=${PRIO_FROM}

[RoutingPolicyRule]
IncomingInterface=${MAIN_IF}
Table=${RT_TABLE_MAIN_ID}
Priority=${PRIO_IIF}
EOF
}

# Enable and start services, configure resolv.conf if resolved present
enable_services() {
  # Enable and start networkd
  systemctl enable --now systemd-networkd

  # If systemd-resolved exists, enable and start it and link resolv.conf
  if systemctl list-unit-files --type=service | grep -q '^systemd-resolved.service'; then
    systemctl enable --now systemd-resolved
    # Link resolv.conf to the stub resolver
    ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
  else
    echo "systemd-resolved not present. Ensure DNS is configured by DHCP or /etc/resolv.conf." >&2
  fi
}

# Apply configuration immediately
apply_now() {
  # Reload networkd configuration and reconfigure interfaces
  systemctl daemon-reload || true
  networkctl reload || true

  # Reconfigure interfaces explicitly
  networkctl reconfigure "${MAIN_IF}" || true
  networkctl reconfigure "${CAM_IF}" || true

  # Flush route cache
  ip route flush cache || true
}

# Verification output
verify() {
  echo
  echo "=== Verification ==="
  echo
  echo "**Interfaces and addresses**"
  ip -br addr
  echo
  echo "**Policy rules**"
  ip rule show
  echo
  echo "**Routes table ${RT_TABLE_CAM_NAME} (${RT_TABLE_CAM_ID})**"
  ip route show table "${RT_TABLE_CAM_ID}" || true
  echo
  echo "**Routes table ${RT_TABLE_MAIN_NAME} (${RT_TABLE_MAIN_ID})**"
  ip route show table "${RT_TABLE_MAIN_ID}" || true
  echo
  echo "**Route decisions**"
  ip route get 8.8.8.8 from "${CAM_FROM%/*}" 2>/dev/null || true
  ip route get 8.8.8.8 from "${MAIN_FROM%/*}" 2>/dev/null || true
  echo
  echo "**systemd-resolved status**"
  if systemctl is-active --quiet systemd-resolved; then
    resolvectl status || true
  else
    echo "systemd-resolved not active"
    echo "Contents of /etc/resolv.conf:"
    cat /etc/resolv.conf || true
  fi
  echo
  echo "If everything looks correct, reboot to confirm persistence."
}

main() {
  need_root
  check_requirements
  ensure_rt_tables
  write_network_files
  enable_services
  apply_now
  verify
  echo
  echo "Done."
}

main "$@"
